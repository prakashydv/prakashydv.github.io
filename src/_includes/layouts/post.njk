---
layout: layouts/base.njk
---
<article class="post h-entry" itemscope itemtype="http://schema.org/BlogPosting">

  <header class="post-header">
    <h1 class="post-title p-name" itemprop="name headline">{{ title | escape }}</h1>
    <p class="post-meta">
      <time class="dt-published" datetime="{{ date | dateToISO }}" itemprop="datePublished">
        {{ date | postDate }}
      </time>
      {%- if author -%}
        &nbsp;•&nbsp;<span itemprop="author" itemscope itemtype="http://schema.org/Person">
          <span class="p-author h-card" itemprop="name">{{ author }}</span>
        </span>
      {%- endif -%}
    </p>
  </header>

  <div class="post-content e-content" itemprop="articleBody">
    {{ content | safe }}
  </div>

  <a class="u-url" href="{{ page.url }}" hidden></a>
</article>
